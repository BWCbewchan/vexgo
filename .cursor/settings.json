{
  "git.autoRepositoryDetection": "openEditors",
  "git.repositoryScanMaxDepth": 2,
  "typescript.tsserver.maxTsServerMemory": 512,
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/node_modules/**": true,
    "**/.next/**": true,
    "**/out/**": true,
    "**/public/public/**": true,
    "**/assets/**": true,
    "**/public/webapp/**": true
  }
}
